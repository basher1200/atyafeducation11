// ==================== النسخ الاحتياطي ====================
function backupData() {
const students = getAllStudents();
const backup = {
version: '2.0',
date: new Date().toISOString(),
students: students,
settings: {
customFields: localStorage.getItem('custom_form_fields'),
appearance: {
bgColor: localStorage.getItem('app_bg_color'),
bgImage: localStorage.getItem('app_bg_image'),
siteProfile: localStorage.getItem('app_site_profile')
}
}
};
const dataStr = JSON.stringify(backup, null, 2);
const blob = new Blob([dataStr], {type: 'application/json'});
const url = URL.createObjectURL(blob);
const a = document.createElement('a');
a.href = url;
a.download = `backup_platform_${new Date().toISOString().split('T')[0]}.json`;
a.click();
URL.revokeObjectURL(url);
showMessage('✅ تم إنشاء النسخة الاحتياطية', 'success');
}

function restoreBackup(file) {
if(!file) return;
const reader = new FileReader();
reader.onload = function(e) {
try {
const backup = JSON.parse(e.target.result);
if(backup.students && Array.isArray(backup.students)) {
backup.students.forEach(s => saveStudent(s));
if(backup.settings?.customFields) {
localStorage.setItem('custom_form_fields', backup.settings.customFields);
}
if(backup.settings?.appearance) {
if(backup.settings.appearance.bgColor) localStorage.setItem('app_bg_color', backup.settings.appearance.bgColor);
if(backup.settings.appearance.bgImage) localStorage.setItem('app_bg_image', backup.settings.appearance.bgImage);
if(backup.settings.appearance.siteProfile) localStorage.setItem('app_site_profile', backup.settings.appearance.siteProfile);
}
showMessage('✅ تم استعادة النسخة الاحتياطية بنجاح', 'success');
setTimeout(() => location.reload(), 1500);
} else {
showMessage('❌ ملف غير صالح', 'error');
}
} catch(err) {
showMessage('❌ خطأ في قراءة الملف', 'error');
}
};
reader.readAsText(file);
}

// ==================== دوال Google Sheets و Drive ====================
async function saveToGoogleSheets(student) {
try {
const formData = new FormData();
formData.append('action', 'addStudent');
formData.append('studentData', JSON.stringify(student));
const response = await fetch(GOOGLE_SCRIPT_URL, {
method: 'POST',
body: formData,
mode: 'no-cors'
});
console.log('تم إرسال البيانات إلى Google Sheets');
return { success: true };
} catch(error) {
console.error('خطأ في حفظ البيانات:', error);
return { success: false, error: error.message };
}
}

async function uploadToGoogleDrive(file, studentData) {
try {
const fileBase64 = await new Promise((resolve, reject) => {
const reader = new FileReader();
reader.onload = (e) => resolve(e.target.result);
reader.onerror = () => reject(new Error('فشل قراءة الملف'));
reader.readAsDataURL(file);
});
const formData = new FormData();
formData.append('action', 'uploadFile');
formData.append('fileData', fileBase64);
formData.append('fileName', file.name);
formData.append('universityId', studentData.universityId);
formData.append('studentName', studentData.fullName);
await fetch(GOOGLE_SCRIPT_URL, {
method: 'POST',
body: formData,
mode: 'no-cors'
});
return {
success: true,
fileName: file.name,
fileData: fileBase64,
localOnly: false
};
} catch(error) {
console.error('خطأ في رفع الملف:', error);
const fileBase64 = await readFileAsBase64(file);
return {
success: true,
fileName: file.name,
fileData: fileBase64,
localOnly: true
};
}
}

function readFileAsBase64(file) {
return new Promise((resolve, reject) => {
const reader = new FileReader();
reader.onload = (e) => resolve(e.target.result);
reader.onerror = () => reject(new Error('فشل قراءة الملف'));
reader.readAsDataURL(file);
});
}

