// ==================== دوال localStorage ====================
function getAllStudents() {
const students = [];
for(let i = 0; i < localStorage.length; i++) {
const key = localStorage.key(i);
if(key && key.startsWith('student_')) {
try {
const student = JSON.parse(localStorage.getItem(key));
if(student && student.universityId) students.push(student);
} catch(e) {}
}
}
return students;
}

function saveStudent(student) {
if(!student || !student.universityId) return;
localStorage.setItem('student_' + student.universityId, JSON.stringify(student));
displayAllStudents();
refreshProAdminPanel();
}

