function loadCustomFields() {
const saved = localStorage.getItem('custom_form_fields');
if(saved) {
customFields = JSON.parse(saved);
} else {
customFields = [
{ id: 'fullName', label: 'الاسم الكامل', type: 'text', required: true, visible: true, order: 1 },
{ id: 'major', label: 'التخصص', type: 'text', required: true, visible: true, order: 2 },
{ id: 'universityId', label: 'الرقم الجامعي', type: 'text', required: true, visible: true, order: 3 },
{ id: 'password', label: 'كلمة السر', type: 'password', required: true, visible: true, order: 4 },
{ id: 'phone', label: 'رقم الجوال', type: 'tel', required: true, visible: true, order: 5 },
{ id: 'coursesCount', label: 'عدد المواد المسجلة', type: 'select', options: ['1', '2', '3', '4', '5', '6', '7'], required: true, visible: true, order: 6 }
