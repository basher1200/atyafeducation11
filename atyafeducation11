function detectGenderFromName(name) {
if(!name) return 'male';
const maleIndicators = ['أحمد', 'محمد', 'علي', 'حسن', 'حسين', 'عمر', 'عثمان', 'خالد', 'عبدالله', 'ياسين', 'زيد', 'حمزة', 'بلال', 'سامي', 'وليد', 'محمود', 'إبراهيم', 'يوسف', 'أمين', 'طارق', 'سعد', 'فهد', 'نواف'];
const femaleIndicators = ['فاطمة', 'زينب', 'عائشة', 'نورا', 'سارة', 'مريم', 'خلود', 'روان', 'ليلى', 'رنا', 'هند', 'أميرة', 'رؤى', 'منى', 'هدى', 'شيماء', 'أسماء', 'نورة', 'الجوهرة', 'لمى'];

for(let i = 0; i < maleIndicators.length; i++) {
if(name.includes(maleIndicators[i])) return 'male';
}
for(let i = 0; i < femaleIndicators.length; i++) {
if(name.includes(femaleIndicators[i])) return 'female';
}
return 'male';
}

