function renderFieldsList() {
const container = document.getElementById('fieldsList');
if(!container) return;

container.innerHTML = '<h5 style="margin-bottom:10px;">📋 ترتيب الحقول</h5>';

customFields.sort(function(a, b) { return a.order - b.order; });

for(let i = 0; i < customFields.length; i++) {
const field = customFields[i];
const isBasic = ['fullName', 'universityId', 'password', 'major', 'phone', 'coursesCount'].indexOf(field.id) !== -1;

const fieldDiv = document.createElement('div');
fieldDiv.className = 'field-item';
fieldDiv.innerHTML = '<div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">' +
'<span style="cursor:move;">☰</span>' +
'<strong>' + field.label + '</strong> (' + field.type + ') ' +
(field.required ? '<span style="color:red;">*</span>' : '') +
'</div>' +
'<div class="field-actions">' +
'<button class="edit-field-btn" data-id="' + field.id + '" style="background:#f39c12;">✏️</button>' +
'<button class="toggle-field-btn" data-id="' + field.id + '" style="background:' + (field.visible ? '#e74c3c' : '#27ae60') + ';">' + (field.visible ? 'إخفاء' : 'إظهار') + '</button>' +
(!isBasic ? '<button class="delete-field-btn" data-id="' + field.id + '" style="background:#e74c3c;">🗑️</button>' : '') +
'</div>';

container.appendChild(fieldDiv);
}

document.querySelectorAll('.edit-field-btn').forEach(btn => {
btn.onclick = function() { editField(this.getAttribute('data-id')); };
});
document.querySelectorAll('.toggle-field-btn').forEach(btn => {
btn.onclick = function() { toggleField(this.getAttribute('data-id')); };
});
document.querySelectorAll('.delete-field-btn').forEach(btn => {
btn.onclick = function() { deleteField(this.getAttribute('data-id')); };
});
}

function renderRegistrationForm() {
const container = document.getElementById('customFieldsContainer');
if(!container) return;

container.innerHTML = '';

customFields.sort(function(a, b) { return a.order - b.order; });

const basicFields = ['fullName', 'major', 'universityId', 'password', 'phone', 'coursesCount'];

for(let i = 0; i < customFields.length; i++) {
const field = customFields[i];
if(!field.visible) continue;

if(field.id === 'fullName') {
const div = document.createElement('div');
div.className = 'form-group';
div.innerHTML = '<label>الاسم الكامل *</label><input type="text" id="fullName" placeholder="أدخل اسمك الكامل" onkeyup="updateInfoCard()">';
container.appendChild(div);
}
else if(field.id === 'major') {
const div = document.createElement('div');
div.className = 'form-group';
div.innerHTML = '<label>التخصص *</label><input type="text" id="major" placeholder="أدخل تخصصك" onkeyup="updateInfoCard()">';
container.appendChild(div);
}
else if(basicFields.indexOf(field.id) === -1) {
const fieldDiv = document.createElement('div');
fieldDiv.className = 'form-group custom-field';
const label = document.createElement('label');
label.textContent = field.label + (field.required ? ' *' : '');
fieldDiv.appendChild(label);

if(field.type === 'select') {
const select = document.createElement('select');
select.id = field.id;
select.required = field.required;
const options = field.options || [];
for(let j = 0; j < options.length; j++) {
const option = document.createElement('option');
option.value = options[j];
option.textContent = options[j];
select.appendChild(option);
}
fieldDiv.appendChild(select);
} else if(field.type === 'textarea') {
const textarea = document.createElement('textarea');
textarea.id = field.id;
textarea.rows = 3;
textarea.required = field.required;
textarea.placeholder = 'أدخل ' + field.label;
fieldDiv.appendChild(textarea);
} else {
const input = document.createElement('input');
input.type = field.type;
input.id = field.id;
input.placeholder = 'أدخل ' + field.label;
input.required = field.required;
fieldDiv.appendChild(input);
}
container.appendChild(fieldDiv);
}
}
}

function addNewField() {
const type = document.getElementById('newFieldType').value;
const label = document.getElementById('newFieldLabel').value.trim();
const id = document.getElementById('newFieldId').value.trim();
const optionsText = document.getElementById('newFieldOptions').value;

if(!label || !id) {
showMessage('❌ الرجاء إدخال اسم الحقل والمعرف', 'error');
return;
}

for(let i = 0; i < customFields.length; i++) {
if(customFields[i].id === id) {
showMessage('❌ هذا المعرف موجود بالفعل', 'error');
return;
}
}

const newField = {
id: id,
label: label,
type: type,
required: false,
visible: true,
order: customFields.length + 1
};

if(type === 'select' && optionsText) {
newField.options = optionsText.split(',').map(function(s) { return s.trim(); });
}

customFields.push(newField);
localStorage.setItem('custom_form_fields', JSON.stringify(customFields));
loadCustomFields();
closeAddFieldModal();
showMessage('✅ تم إضافة الحقل بنجاح', 'success');
}

function editField(fieldId) {
let field = null;
for(let i = 0; i < customFields.length; i++) {
if(customFields[i].id === fieldId) {
field = customFields[i];
break;
}
}
if(!field) return;

const newLabel = prompt('تعديل التسمية:', field.label);
if(newLabel && newLabel.trim()) field.label = newLabel.trim();

const newRequired = confirm('هل الحقل إلزامي؟\nاضغط OK للإلزامي، Cancel لاختياري');
field.required = newRequired;

localStorage.setItem('custom_form_fields', JSON.stringify(customFields));
loadCustomFields();
showMessage('✅ تم تعديل الحقل', 'success');
}

function toggleField(fieldId) {
for(let i = 0; i < customFields.length; i++) {
if(customFields[i].id === fieldId) {
customFields[i].visible = !customFields[i].visible;
break;
}
}
localStorage.setItem('custom_form_fields', JSON.stringify(customFields));
loadCustomFields();
showMessage('✅ تم تغيير حالة الحقل', 'success');
}

function deleteField(fieldId) {
const basicFields = ['fullName', 'universityId', 'password', 'major', 'phone', 'coursesCount'];
if(basicFields.indexOf(fieldId) !== -1) {
showMessage('❌ لا يمكن حذف الحقول الأساسية', 'error');
return;
}
if(confirm('هل أنت متأكد من حذف هذا الحقل؟')) {
const newFields = [];
for(let i = 0; i < customFields.length; i++) {
if(customFields[i].id !== fieldId) {
newFields.push(customFields[i]);
}
}
customFields = newFields;
localStorage.setItem('custom_form_fields', JSON.stringify(customFields));
loadCustomFields();
showMessage('✅ تم حذف الحقل', 'success');
}
}

function resetFormToDefault() {
if(confirm('⚠️ هل أنت متأكد؟ سيتم حذف جميع الحقول المضافة واستعادة النموذج الأصلي')) {
localStorage.removeItem('custom_form_fields');
loadCustomFields();
showMessage('✅ تم إعادة تعيين النموذج', 'success');
}
}

